import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner s=new Scanner(System.in);
		int n=s.nextInt();
		int arr[]=new int[n];
		for(int i=0;i<arr.length;i++){
		    arr[i]=s.nextInt();
		}
		
		for(int i=1;i<arr.length;i++){
		    int j=i-1;
		    int key=arr[i];
		    
		    while(j>=0 && arr[j]>key){
		        arr[j+1]=arr[j];
		        j--;
		    }
		    arr[j+1]=key;
		}
		
		for(int num:arr){
		    System.out.println(num+" ");
		}
		
	}
}
