import java.util.*;
class Node{
    int data;
    Node next;
    Node(int data){
        this.data=data;
        this.next=null;
    }
}

class LinkedList{
    Node head=null;
    Node temp=null;
    void insertAtBegin(int data){
        Node newNode=new Node(data);
        newNode.next=head;
        head=newNode;
    }
    
    void deleteAtPos(int pos){
        
        if(head==null){
            System.out.println("List is Empty");
            return;
        }
        
        if(pos==0){
            head=head.next;
            System.out.println("\nLast node is deleted"+pos);
            return;
        }
        temp=head;
        for(int i=0;i<pos-1;i++){
            if(temp.next==null){
                System.out.println("Invalid pos");
                return;
            }
            temp=temp.next;
        }
        if(temp.next==null){
                System.out.println("Invalid pos");
                return;
            }
        
        temp.next=temp.next.next;
    }
    
    void display(){
        temp=head;
        while(temp!=null){
            System.out.print(temp.data+"->");
            temp=temp.next;
        }
        System.out.print("null");
    }
}
class Main {
    public static void main(String[] args) {
        Scanner s=new Scanner(System.in);
        LinkedList list=new LinkedList();
        int n=s.nextInt();
        
        for(int i=0;i<n;i++){
            int value=s.nextInt();
            list.insertAtBegin(value);
        }
        System.out.println("Before deletion");
        list.display();
        
        int pos=s.nextInt();
        
        list.deleteAtPos(pos);
        System.out.println("\nAfter deletion");
        list.display();
        
    }
}
